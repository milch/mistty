+    /// Mistty patch: expose the shell (or user-specified `command`) child
+    /// process PID so the host app can resolve the foreground process on the
+    /// surface's tty via `tcgetpgrp` / `proc_*`. Returns `-1` when the child
+    /// hasn't started yet, has exited, or the termio backend isn't a
+    /// standard POSIX fork/exec subprocess.
+    export fn ghostty_surface_command_pid(surface: *Surface) c_int {
+        const core = &surface.core_surface;
+        switch (core.io.backend) {
+            .exec => |*exec| {
+                const process = exec.subprocess.process orelse return -1;
+                switch (process) {
+                    .fork_exec => |cmd| {
+                        const pid = cmd.pid orelse return -1;
+                        return @as(c_int, @intCast(pid));
+                    },
+                    .flatpak => return -1,
+                }
+            },
+        }
+    }
