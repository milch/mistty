+    /// Mistty patch: expose the pty master fd for this surface so the host
+    /// app can call `tcgetpgrp(fd)` to find the foreground process group on
+    /// the tty. Returns `-1` when the pty hasn't been opened yet or the
+    /// termio backend isn't `.exec`.
+    export fn ghostty_surface_pty_fd(surface: *Surface) c_int {
+        const core = &surface.core_surface;
+        switch (core.io.backend) {
+            .exec => |*exec| {
+                if (exec.subprocess.pty) |pty| {
+                    return @as(c_int, @intCast(pty.master));
+                }
+                return -1;
+            },
+        }
+    }
